# Optional OpenAI-compatible text/image API settings.
# Keep these empty to run the offline synthetic demo.

LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

IMAGE_API_URL=
IMAGE_API_KEY=
IMAGE_API_MODEL=
IMAGE_API_RESPONSE_MODE=url

# Optional local/API provider choices used by configs/default.json.
TEXT_EMBEDDING_MODEL=
IMAGE_GENERATION_PROVIDER=placeholder

# Optional Neo4j graph database settings.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
