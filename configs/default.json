{
  "project_name": "campus_match_ai",
  "seed": 42,
  "n_users": 120,
  "top_k": 5,
  "embedding_dim": 384,
  "paths": {
    "data_dir": "data",
    "images_dir": "images",
    "indexes_dir": "indexes",
    "outputs_dir": "outputs"
  },
  "generation": {
    "use_llm_profile_extraction": false,
    "image_provider": "placeholder",
    "image_kind": "lifestyle",
    "generate_prompt_files": true
  },
  "embedding": {
    "text_provider": "auto",
    "text_model_name": ".hf-models/paraphrase-multilingual-MiniLM-L12-v2",
    "image_provider": "color_histogram",
    "clip_model_name": "openai/clip-vit-base-patch32"
  },
  "matching": {
    "weights": {
      "text_similarity": 0.27,
      "graph_similarity": 0.22,
      "value_similarity": 0.18,
      "goal_match": 0.10,
      "communication_match": 0.05,
      "image_similarity": 0.08,
      "gnn_link_score": 0.10
    },
    "penalties": {
      "strong_goal_conflict": 0.30,
      "deal_breaker_hit": 0.40,
      "campus_distance": 0.05,
      "communication_conflict": 0.12
    }
  },
  "scene_matching": {
    "enabled": true,
    "n_requests": 12,
    "top_k": 5,
    "description": "Dynamic scene-based buddy matching with simulated location, time window, task intent and safety context."
  },
  "relationship_dynamics": {
    "enabled": true,
    "max_pairs": 8,
    "days": 7,
    "description": "Synthetic relationship heat curves and profile update signals based on aggregate chat metrics."
  },
  "date_context": {
    "enabled": true,
    "max_plans": 8,
    "description": "Synthetic offline date context with simulated LBS, weather, location safety and RAG-style suggestions."
  },
  "governance": {
    "enabled": true,
    "description": "Synthetic knowledge-governance policy for credit score, conditional mute, cooldown and recommendation downranking."
  }
}
